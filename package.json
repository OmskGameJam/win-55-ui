{
  "name": "win-55-ui-vue",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./plugin": {
      "types": "./plugin.d.ts",
      "import": "./plugin.js"
    }
  },
  "files": [
    "dist",
    "public/win-55-ui",
    "plugin.js",
    "plugin.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && vue-tsc --project tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "npm run build:lib"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.8"
  }
}
